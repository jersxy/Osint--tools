<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xzerdn // Threat Intel Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Courier New', Courier, monospace;
        }

        body {
            background-color: #0a0f1d;
            color: #00ff66; /* Warna ijo terminal */
            padding: 20px;
        }

        .wrapper {
            max-width: 900px;
            margin: 0 auto;
            border: 1px solid #00ff66;
            padding: 20px;
            box-shadow: 0 0 15px rgba(0, 255, 102, 0.2);
            background: #0d1527;
        }

        header {
            text-align: center;
            border-bottom: 2px dashed #00ff66;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        header h1 {
            font-size: 1.8rem;
            text-shadow: 0 0 8px rgba(0, 255, 102, 0.6);
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
        }

        .card {
            border: 1px solid #005511;
            background: #070c16;
            padding: 15px;
            border-radius: 4px;
        }

        .card h3 {
            color: #fff;
            margin-bottom: 10px;
            font-size: 1.1rem;
            border-bottom: 1px solid #00ff66;
            padding-bottom: 5px;
        }

        input, select, button {
            width: 100%;
            padding: 10px;
            background: #111a2e;
            border: 1px solid #00ff66;
            color: #fff;
            margin-top: 8px;
            font-family: inherit;
        }

        button {
            background: #00ff66;
            color: #000;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

        button:hover {
            background: #fff;
            border-color: #fff;
            box-shadow: 0 0 10px #fff;
        }

        .result-box {
            margin-top: 15px;
            background: #050811;
            padding: 10px;
            border-left: 3px solid #ff3333;
            font-size: 0.85rem;
            color: #00ffbb;
            white-space: pre-line;
            min-height: 50px;
        }
    </style>
</head>
<body>

<div class="wrapper">
    <header>
        <h1>[ XZERDN THREAT INTEL & OSINT CENTER ]</h1>
        <p style="color: #888; font-size: 0.8rem; margin-top: 5px;">Sistem Pemantauan & Investigasi Target Sederhana</p>
    </header>

    <div class="grid">
        <div class="card">
            <h3>1. IP Address Target Tracer</h3>
            <p style="font-size: 0.8rem; color: #aaa;">Lacak lokasi, ISP, dan data publik dari IP Target.</p>
            <input type="text" id="ipInput" placeholder="Masukkan IP (Contoh: 8.8.8.8)">
            <button onclick="traceIP()">Lacak IP Target</button>
            <div class="result-box" id="ipResult">> Masukkan IP lalu klik lacak...</div>
        </div>

        <div class="card">
            <h3>2. Google Dorking Generator</h3>
            <p style="font-size: 0.8rem; color: #aaa;">Instan nyari file log, vuln, atau admin panel di target.</p>
            <input type="text" id="targetDomain" placeholder="Target Domain (Contoh: target.com)">
            <select id="dorkType">
                <option value="admin">Cari Halaman Login Admin</option>
                <option value="config">Cari File Konfigurasi (.env, .conf)</option>
                <option value="log">Cari File Log Bocor (.log)</option>
            </select>
            <button onclick="generateDork()">Eksekusi Google Dork</button>
        </div>
    </div>

    <footer style="margin-top: 30px; text-align: center; font-size: 0.75rem; color: #555; border-top: 1px dashed #333; padding-top: 15px;">
        Console Version 1.0 // Terkoneksi ke API Publik // Jaga Anonimitas Lu.
    </footer>
</div>

<script>
    // FUNGSI LACAK IP PAKE API GRATISAN
    async function traceIP() {
        const ip = document.getElementById('ipInput').value.trim();
        const resultBox = document.getElementById('ipResult');
        
        if (!ip) {
            resultBox.innerText = "> Woi, isi dulu IP-nya cok!";
            return;
        }

        resultBox.innerText = "> Sedang melakukan querying ke database...";

        try {
            const response = await fetch(`https://ipapi.co/${ip}/json/`);
            if (!response.ok) throw new Error();
            const data = await response.json();

            if(data.error) {
                resultBox.innerText = `> Error: ${data.reason}`;
                return;
            }

            resultBox.innerHTML = `
                <b>[ STATUS SECURE ]</b><br>
                IP      : ${data.ip}<br>
                Kota    : ${data.city}, ${data.region}<br>
                Negara  : ${data.country_name}<br>
                ISP     : ${data.org}<br>
                Lat/Lon : ${data.latitude}, ${data.longitude}
            `;
        } catch (error) {
            resultBox.innerText = "> Gagal mengambil data. Pastikan IP valid atau kuota API habis.";
        }
    }

    // FUNGSI GENERATE GOOGLE DORK DAN LANGSUNG BUKA TAB BARU
    function generateDork() {
        const domain = document.getElementById('targetDomain').value.trim();
        const type = document.getElementById('dorkType').value;

        if (!domain) {
            alert("Isi domain targetnya dulu cok!");
            return;
        }

        let query = "";
        if (type === "admin") {
            query = `site:${domain} inurl:admin | login | wp-login`;
        } else if (type === "config") {
            query = `site:${domain} ext:env | ext:yaml | ext:conf | ext:txt "DB_PASSWORD"`;
        } else if (type === "log") {
            query = `site:${domain} ext:log | inurl:log`;
        }

        // Buka tab google otomatis dengan dorking-nya
        const googleUrl = `https://www.google.com/search?q=${encodeURIComponent(query)}`;
        window.open(googleUrl, '_blank');
    }
</script>

</body>
</html>
